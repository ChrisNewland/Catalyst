generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Cat {
  id            String     @id @default(cuid())
  name          String
  intakeDate    DateTime   @default(now())
  dob           DateTime?
  notes         String     @default("")
  medicalFlags  String     @default("")
  archivedAt    DateTime?
  createdAt     DateTime   @default(now())
  logEntries    LogEntry[]

  @@index([archivedAt])
}

model LogEntry {
  id             String   @id @default(cuid())
  catId          String
  loggedByName   String   // required free-text: who recorded the visit
  recordedAt     DateTime @default(now())

  foodOffered    String   // "NONE" | "SOME" | "ALL"
  waterIntake    String   // "NONE" | "SOME" | "NORMAL"
  urinated       Boolean  @default(false)
  defecated      Boolean  @default(false)
  bristolScore   Int?     // 1..7, only when defecated
  weightGrams    Int?
  condition      String   @default("GOOD") // "GOOD" | "CONCERN" | "URGENT"
  behaviourNotes String?
  generalNotes   String?

  cat Cat @relation(fields: [catId], references: [id], onDelete: Cascade)

  @@index([catId, recordedAt])
}
