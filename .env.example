DATABASE_URL="file:./dev.db"
AUTH_SECRET="change-me-in-production-run-openssl-rand-base64-32"
AUTH_TRUST_HOST=true

# Shared passwords for the shelter. Volunteers sign in with one, admins with the other.
# Anyone with the volunteer password can record visits; anyone with the admin password
# additionally gets the /admin pages for managing cats.
SHELTER_VOLUNTEER_PASSWORD="change-me-volunteer"
SHELTER_ADMIN_PASSWORD="change-me-admin"
